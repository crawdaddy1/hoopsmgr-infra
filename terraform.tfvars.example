aws_region    = "us-east-1"
project_name  = "hoopsmgr"
instance_type = "t3.micro"
key_name      = "laptop_key"
domain_name   = "hoopsmanager.com"

# Pinned AL2023 AMI. Bump explicitly via `scripts/rotate-ami.sh` when AWS
# publishes a refresh — leave alone otherwise so unrelated `terraform apply`
# runs don't surprise-replace the instance.
# ec2_ami_id    = "ami-0fc6cf99992956a4a"
